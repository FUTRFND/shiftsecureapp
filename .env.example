# Environment variables — copy to `.env.local` and fill in.
# Anything prefixed with VITE_ is exposed to the browser bundle.
# Everything else is server-only (TanStack server functions / Edge Functions).

# --- Supabase (client) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- Supabase (server) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Lovable AI Gateway (server only — never expose to the client) ---
LOVABLE_API_KEY=

# --- RevenueCat (client; public SDK keys — safe in the mobile bundle) ---
# Provisioned in Phase 7. Leave blank until then.
VITE_REVENUECAT_IOS_KEY=
VITE_REVENUECAT_ANDROID_KEY=

# --- Mobile deep linking ---
# The custom URL scheme and Universal/App Link host used by the Capacitor app.
# Add these as Additional Redirect URLs in Supabase Auth → URL Configuration.
VITE_APP_URL_SCHEME=handoffhero
VITE_APP_UNIVERSAL_LINK_HOST=handoffhero.app
